---
const siteUrl = "https://agedpawwell.com";
const siteName = "Senior Dog Community";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Community", href: "#community", hasDropdown: true },
  { label: "Senior Dog Health", href: "#health" },
  { label: "Conditions", href: "#conditions" },
  { label: "Reviews", href: "#reviews" },
  { label: "Blog", href: "#blog" },
  { label: "Membership", href: "#membership" },
  { label: "About", href: "#about" },
];

const communityDropdown = [
  { label: "Senior Dog Club", href: "#community" },
  { label: "Breed Specific Rooms", href: "#community" },
  { label: "Care Topic Rooms", href: "#community" },
  { label: "Ask the Community", href: "#community" },
  { label: "Live Discussions", href: "#community" },
  { label: "Member Success Stories", href: "#community" },
];

const rooms = [
  { name: "Joint Care Room", desc: "Managing arthritis, hip dysplasia, and mobility", icon: "🦴", count: "4,281", priority: true },
  { name: "Kidney Care Room", desc: "Kidney disease support and dietary guidance", icon: "🫘", count: "2,103", priority: false },
  { name: "Heart Health Room", desc: "Heart conditions and cardiovascular support", icon: "❤️", count: "1,876", priority: false },
  { name: "Mobility Room", desc: "Ramps, slings, and movement assistance", icon: "🚶", count: "3,445", priority: false },
  { name: "Nutrition Room", desc: "Senior dog food, supplements, and diet plans", icon: "🍖", count: "2,891", priority: false },
  { name: "Golden Retriever Room", desc: "Breed-specific care for golden seniors", icon: "🐕", count: "1,654", priority: false },
  { name: "Labrador Room", desc: "Lab-specific health topics and community", icon: "🐕‍🦺", count: "1,432", priority: false },
  { name: "German Shepherd Room", desc: "GSD senior health and hereditary concerns", icon: "🦮", count: "987", priority: false },
  { name: "Small Senior Dogs Room", desc: "Tiny seniors: toy breeds and aging", icon: "🐶", count: "2,218", priority: false },
];

const healthCards = [
  { title: "Preventive Care", desc: "Regular vet checkups and early detection strategies", icon: "🩺" },
  { title: "Diet & Nutrition", desc: "Optimal feeding for aging dogs at every stage", icon: "🍖" },
  { title: "Gentle Exercise", desc: "Safe activities to keep your senior mobile", icon: "🚶" },
  { title: "Home Comfort", desc: "Adapting your home for an aging companion", icon: "🏠" },
  { title: "Wellness Checks", desc: "Monitoring health changes at home", icon: "📋" },
];

const conditions = [
  { name: "Arthritis", signs: "Stiffness, limping, reluctance to climb stairs", urgency: "Schedule visit 1-2 weeks", color: "bg-teal-50 border-teal-200" },
  { name: "Cognitive Dysfunction", signs: "Confusion, night waking, house soiling", urgency: "Schedule visit 1-2 weeks", color: "bg-indigo-50 border-indigo-200" },
  { name: "Heart Disease", signs: "Coughing, breathing difficulty, fainting", urgency: "Urgent: see vet in 48h", color: "bg-rose-50 border-rose-200" },
  { name: "Kidney Disease", signs: "Increased thirst, weight loss, vomiting", urgency: "Schedule visit within 1 week", color: "bg-sky-50 border-sky-200" },
  { name: "Diabetes", signs: "Excessive thirst, weight loss, lethargy", urgency: "Urgent: see vet within 48h", color: "bg-amber-50 border-amber-200" },
  { name: "Cancer", signs: "Lumps, unexplained weight loss, non-healing wounds", urgency: "Schedule visit 1-2 weeks", color: "bg-violet-50 border-violet-200" },
  { name: "Dental Disease", signs: "Bad breath, drooling, difficulty eating", urgency: "Schedule visit 2-4 weeks", color: "bg-orange-50 border-orange-200" },
  { name: "Vision Loss", signs: "Bumping into objects, hesitating at edges", urgency: "Schedule routine checkup", color: "bg-slate-50 border-slate-200" },
  { name: "Hearing Loss", signs: "Not responding to commands, startling easily", urgency: "Schedule routine checkup", color: "bg-gray-50 border-gray-200" },
  { name: "Obesity", signs: "Excess weight, difficulty moving, fatigue", urgency: "Schedule visit 1-2 weeks", color: "bg-green-50 border-green-200" },
];

const reviews = [
  { category: "Joint Supplements", rating: 4.7, verdict: "Top-rated by vets and owners for arthritis support", badge: "Vet & Owner Tested" },
  { category: "Senior Dog Food", rating: 4.5, verdict: "Best formulas for aging digestive systems and weight", badge: "Vet & Owner Tested" },
  { category: "Mobility Aids", rating: 4.3, verdict: "Ramps, slings, and carts that actually work", badge: "Vet & Owner Tested" },
  { category: "Comfort Beds", rating: 4.8, verdict: "Orthopedic beds that ease joint pressure", badge: "Vet & Owner Tested" },
];

const blogPosts = [
  { title: "Managing Arthritis in Senior Dogs", excerpt: "Evidence-based strategies to keep your aging dog comfortable and mobile.", readTime: "6 min read", img: "https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=600&q=80" },
  { title: "Best Foods for Aging Dogs in 2026", excerpt: "Veterinarian-reviewed guide to senior dog nutrition and supplements.", readTime: "8 min read", img: "https://images.unsplash.com/photo-1601758124096-1fd661873b95?auto=format&fit=crop&w=600&q=80" },
  { title: "When to Consider Palliative Care", excerpt: "Making compassionate end-of-life decisions with your vet.", readTime: "10 min read", img: "https://images.unsplash.com/photo-1583511655857-d19b40a7a54e?auto=format&fit=crop&w=600&q=80" },
];

const membershipBenefits = [
  "Save personalized custom dog care guides",
  "Unlock exclusive breed & health community rooms",
  "Directly ask vets & experienced dog parents questions",
  "Free digital senior dog health record tracker",
  "Weekly professional senior care newsletter delivery",
];

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: siteName,
  url: siteUrl,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Senior Dog Community | Health Support for Aging Dogs</title>
    <meta name="description" content="The #1 senior dog owner community. Access vet-backed health guides, trusted condition resources, unbiased product reviews, and connect with experienced senior dog parents worldwide." />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl + "/"} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content="Senior Dog Community | Health Support for Aging Dogs" />
    <meta property="og:description" content="The #1 senior dog owner community. Access vet-backed health guides, trusted condition resources, and connect with experienced senior dog parents worldwide." />
    <meta property="og:image" content="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1200&q=80" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    <style>
      @tailwind base;
      @tailwind components;
      @tailwind utilities;
      @tailwind utilities;
    </style>
  </head>
  <body class="bg-white text-slate-800 antialiased" x-data="{ mobileMenu: false, communityOpen: false }">

    <!-- NAVIGATION -->
    <header class="sticky top-0 z-50 bg-slate-900 shadow-lg">
      <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8" aria-label="Primary navigation">
        <div class="flex h-16 items-center justify-between">
          <a href="/" class="flex items-center gap-2 text-white font-bold text-lg tracking-wide">
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-teal-600 text-sm font-bold text-white">SD</span>
            <span class="hidden sm:block">Senior Dog Community</span>
          </a>

          <!-- Desktop Nav -->
          <div class="hidden lg:flex items-center gap-1">
            {navLinks.map(link => (
              link.label === "Community" ? (
                <div class="relative" x-data="{ open: false }">
                  <button
                    @mouseenter="open = true"
                    @mouseleave="open = false"
                    @click="open = !open"
                    class="flex items-center gap-1 px-3 py-2 text-sm font-medium text-white/90 hover:text-white rounded-md hover:bg-white/10 transition-colors cursor-pointer"
                  >
                    {link.label}
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </button>
                  <div
                    x-show="open"
                    x-transition:enter="transition ease-out duration-100"
                    x-transition:enter-start="opacity-0 scale-95"
                    x-transition:enter-end="opacity-100 scale-100"
                    x-transition:leave="transition ease-in duration-75"
                    x-transition:leave-start="opacity-100 scale-100"
                    x-transition:leave-end="opacity-0 scale-95"
                    @mouseenter="open = true"
                    @mouseleave="open = false"
                    class="absolute left-0 top-full mt-1 w-56 rounded-xl bg-white shadow-xl border border-slate-100 py-2 text-sm z-50"
                  >
                    {communityDropdown.map(item => (
                      <a href={item.href} class="block px-4 py-2 text-slate-700 hover:bg-teal-50 hover:text-teal-700">{item.label}</a>
                    ))}
                  </div>
                </div>
              ) : (
                <a href={link.href} class="px-3 py-2 text-sm font-medium text-white/90 hover:text-white rounded-md hover:bg-white/10 transition-colors">{link.label}</a>
              )
            ))}
            <a href="#membership" class="ml-3 inline-flex items-center rounded-full bg-red-600 px-5 py-2 text-sm font-semibold text-white hover:bg-red-700 transition-colors">
              Join Free
            </a>
          </div>

          <!-- Mobile hamburger -->
          <button
            @click="mobileMenu = !mobileMenu"
            class="lg:hidden text-white p-2 rounded-md hover:bg-white/10"
            aria-label="Toggle menu"
          >
            <svg x-show="!mobileMenu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
            <svg x-show="mobileMenu" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        </div>

        <!-- Mobile Menu -->
        <div x-show="mobileMenu" x-transition class="lg:hidden pb-4">
          {navLinks.map(link => (
            <a href={link.href} class="block py-2 text-sm font-medium text-white/80 hover:text-white">{link.label}</a>
          ))}
          <a href="#membership" class="mt-2 inline-flex items-center rounded-full bg-red-600 px-5 py-2 text-sm font-semibold text-white">Join Free</a>
        </div>
      </nav>
    </header>

    <main>
      <!-- SECTION 1: HERO -->
      <section class="relative bg-gradient-to-br from-slate-900 to-slate-800 text-white overflow-hidden">
        <div class="absolute inset-0 opacity-20">
          <img src="https://images.unsplash.com/photo-1587300003388-59208cc962cb?auto=format&fit=crop&w=1600&q=80" alt="" class="w-full h-full object-cover" />
        </div>
        <div class="relative mx-auto max-w-4xl px-4 py-20 sm:px-6 sm:py-28 lg:px-8 text-center">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
            The #1 Senior Dog Owner Community
          </h1>
          <p class="mt-4 text-xl sm:text-2xl text-white/90 font-medium">
            Helping aging dogs stay active, comfortable, and healthy.
          </p>
          <p class="mt-4 text-base sm:text-lg text-white/70 max-w-2xl mx-auto">
            Access vet-backed health guides, trusted condition resources, unbiased product reviews, and connect with experienced senior dog parents worldwide.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row gap-4 justify-center">
            <a href="#membership" class="inline-flex items-center justify-center rounded-full bg-red-600 px-8 py-4 text-base font-semibold text-white hover:bg-red-700 transition-colors min-h-[52px]">
              Join the Community
            </a>
            <a href="#health" class="inline-flex items-center justify-center rounded-full border-2 border-white/60 px-8 py-4 text-base font-semibold text-white hover:bg-white/10 transition-colors min-h-[52px]">
              Explore Health Guides
            </a>
          </div>
        </div>
      </section>

      <!-- SECTION 2: LIVE COMMUNITY ACTIVITY -->
      <section class="bg-teal-50 border-b border-teal-100" aria-labelledby="community-title">
        <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
          <div class="text-center mb-8">
            <div class="inline-flex items-center gap-2 rounded-full bg-teal-100 px-4 py-1.5 text-sm font-semibold text-teal-800 mb-3">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-teal-500 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-teal-600"></span>
              </span>
              2,847 Senior Dog Parents Online Now
            </div>
            <h2 id="community-title" class="text-3xl font-bold text-slate-950">Welcome to the Community</h2>
            <p class="mt-2 text-slate-600">Real questions, real answers, from real senior dog parents.</p>
          </div>

          <div class="grid gap-4 sm:grid-cols-3 mb-8">
            {[
              { topic: "Best joint supplements?", replies: 234, room: "Joint Care Room" },
              { topic: "Managing arthritis at home", replies: 189, room: "Mobility Room" },
              { topic: "Senior dog nutrition tips", replies: 156, room: "Nutrition Room" },
            ].map(item => (
              <a href="#community" class="group rounded-xl border border-teal-200 bg-white p-5 shadow-sm hover:shadow-md hover:border-teal-400 transition-all">
                <p class="font-semibold text-slate-900 group-hover:text-teal-700">"{item.topic}"</p>
                <p class="mt-2 text-xs text-slate-500">{item.replies} replies &middot; {item.room}</p>
              </a>
            ))}
          </div>

          <div class="bg-white rounded-xl border border-slate-200 p-6">
            <h3 class="font-bold text-slate-900 mb-4">Latest from the community</h3>
            <div class="space-y-4">
              {[
                { user: "Margaret T.", avatar: "M", text: "Just started my 14-year-old beagle on glucosamine. Any tips for the first week?", room: "Joint Care Room", time: "3 min ago" },
                { user: "Dr. Sarah K.", avatar: "S", text: "Great question Margaret! Start with a low dose and monitor for digestive upset. Most dogs adjust within a few days.", room: "Joint Care Room", time: "2 min ago" },
                { user: "Tom H.", avatar: "T", text: "Has anyone tried laser therapy for arthritis? Wondering if it is worth the cost.", room: "Mobility Room", time: "1 min ago" },
              ].map(c => (
                <div class="flex gap-3">
                  <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-teal-100 text-teal-800 text-sm font-bold">{c.avatar}</span>
                  <div>
                    <p class="text-sm font-semibold text-slate-800">{c.user} <span class="font-normal text-slate-500">&middot; {c.time}</span></p>
                    <p class="text-sm text-slate-600 mt-0.5">"{c.text}"</p>
                    <p class="text-xs text-teal-600 mt-1">{c.room}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- SECTION 3: MEMBERSHIP TEASER -->
      <section class="bg-slate-900 text-white">
        <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8 text-center">
          <h2 class="text-2xl font-bold">Join 50,000+ Senior Dog Families</h2>
          <p class="mt-2 text-white/70">Free membership. No credit card required.</p>
          <a href="#membership" class="mt-4 inline-flex items-center text-teal-400 hover:text-teal-300 font-medium text-sm">
            Create your free account &rarr;
          </a>
        </div>
      </section>

      <!-- SECTION 4: COMMUNITY ROOMS -->
      <section id="community" class="bg-white" aria-labelledby="rooms-title">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 id="rooms-title" class="text-3xl font-bold text-slate-950">Join Our Community Rooms</h2>
            <p class="mt-2 text-slate-600">Find your people. Get real support from those who understand.</p>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {rooms.map(room => (
              <a
                href="#community"
                class={`group rounded-2xl border p-6 transition-all hover:shadow-lg hover:-translate-y-1 ${
                  room.priority
                    ? 'bg-teal-50 border-teal-300 ring-2 ring-teal-400 relative overflow-hidden'
                    : 'bg-white border-slate-200 hover:border-teal-300'
                }`}
              >
                {room.priority && (
                  <span class="absolute top-3 right-3 rounded-full bg-teal-600 px-2 py-0.5 text-xs font-bold text-white">TOP</span>
                )}
                <span class="text-4xl">{room.icon}</span>
                <h3 class={`mt-3 font-bold ${room.priority ? 'text-teal-900' : 'text-slate-900'} group-hover:text-teal-700`}>{room.name}</h3>
                <p class="mt-1.5 text-sm text-slate-600">{room.desc}</p>
                <p class="mt-3 text-xs font-semibold text-teal-600">{room.count} members</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SECTION 5: SENIOR DOG HEALTH -->
      <section id="health" class="bg-slate-50" aria-labelledby="health-title">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 id="health-title" class="text-3xl font-bold text-slate-950">Daily Care for Your Aging Companion</h2>
            <p class="mt-2 text-slate-600">Practical guidance for everyday wellness and comfort.</p>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-5">
            {healthCards.map(card => (
              <a href="#health" class="group rounded-xl border border-slate-200 bg-white p-5 text-center hover:shadow-md hover:border-teal-300 transition-all">
                <span class="text-3xl">{card.icon}</span>
                <h3 class="mt-3 font-bold text-slate-900 group-hover:text-teal-700">{card.title}</h3>
                <p class="mt-1.5 text-xs text-slate-600 leading-relaxed">{card.desc}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SECTION 6: CONDITIONS ENCYCLOPEDIA -->
      <section id="conditions" class="bg-white" aria-labelledby="conditions-title">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 id="conditions-title" class="text-3xl font-bold text-slate-900">Common Senior Dog Conditions</h2>
            <p class="mt-2 text-slate-600">Symptoms, vet advice, and what to do next.</p>
          </div>
          <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {conditions.map(c => (
              <a href="#conditions" class={`group rounded-xl border-2 p-5 ${c.color} hover:shadow-md transition-all block`}>
                <h3 class="font-bold text-slate-900 text-lg group-hover:text-slate-700">{c.name}</h3>
                <p class="mt-2 text-sm text-slate-700"><strong>Key signs:</strong> {c.signs}</p>
                <p class="mt-3 text-xs font-semibold text-teal-700 bg-white/60 inline-block px-2 py-1 rounded-md">{c.urgency}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SECTION 7: PRODUCT REVIEWS -->
      <section id="reviews" class="bg-slate-50" aria-labelledby="reviews-title">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 id="reviews-title" class="text-3xl font-bold text-slate-950">Vet & Owner Tested Reviews</h2>
            <p class="mt-2 text-slate-600">Honest, unbiased reviews you can trust.</p>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
            {reviews.map(r => (
              <a href="#reviews" class="group rounded-xl border border-slate-200 bg-white p-5 hover:shadow-md transition-all">
                <span class="text-xs font-bold text-teal-700 bg-teal-50 px-2 py-1 rounded-full">{r.badge}</span>
                <h3 class="mt-3 font-bold text-slate-900 group-hover:text-slate-700">{r.category}</h3>
                <div class="mt-2 flex items-center gap-1">
                  {[1,2,3,4,5].map(n => (
                    <svg class={`w-4 h-4 ${n <= Math.round(r.rating) ? 'text-amber-400' : 'text-slate-200'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  ))}
                  <span class="ml-1 text-sm font-semibold text-slate-700">{r.rating}</span>
                </div>
                <p class="mt-2 text-sm text-slate-600 leading-relaxed">{r.verdict}</p>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SECTION 8: BLOG -->
      <section id="blog" class="bg-white" aria-labelledby="blog-title">
        <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
          <div class="text-center mb-10">
            <h2 id="blog-title" class="text-3xl font-bold text-slate-950">Latest from Our Health Blog</h2>
          </div>
          <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {blogPosts.map(post => (
              <a href="#blog" class="group rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg transition-all">
                <div class="aspect-video overflow-hidden">
                  <img src={post.img} alt={post.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" />
                </div>
                <div class="p-5">
                  <h3 class="font-bold text-slate-900 group-hover:text-slate-700 leading-snug">{post.title}</h3>
                  <p class="mt-2 text-sm text-slate-600 leading-relaxed">{post.excerpt}</p>
                  <p class="mt-3 text-xs text-teal-600 font-medium">{post.readTime}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- SECTION 9: FULL MEMBERSHIP -->
      <section id="membership" class="bg-gradient-to-br from-slate-900 to-slate-800 text-white" aria-labelledby="membership-title">
        <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6 lg:px-8 text-center">
          <span class="inline-flex items-center rounded-full bg-teal-600/20 px-4 py-1.5 text-sm font-semibold text-teal-300 mb-4">
            Free Forever
          </span>
          <h2 id="membership-title" class="text-3xl sm:text-4xl font-bold">Free Senior Dog Membership Benefits</h2>
          <p class="mt-3 text-white/70">Everything you need to give your senior dog the best possible life.</p>

